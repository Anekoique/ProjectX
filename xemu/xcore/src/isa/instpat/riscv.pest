// riscv.pest
WHITESPACE = _{ " " | "\t" | "\n" }

file = { SOI ~ instpat_line* ~ EOI }

instpat_line = {
    "INSTPAT(\"" ~ pattern ~ "\", " ~ name ~ ", " ~ inst_type ~ ")" ~ ";"? ~ NEWLINE?
}

pattern   = @{ (ASCII_DIGIT | "?" | " ")+ }
name      = @{ (ASCII_ALPHANUMERIC | "." | "_")+ }
inst_type = @{ ASCII_ALPHANUMERIC+ }